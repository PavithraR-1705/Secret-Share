import java.math.BigInteger;
import java.util.*;
import org.json.JSONObject;

public class Main {

    // Convert any base value to decimal
    public static BigInteger convertToDecimal(String value, int base) {
        return new BigInteger(value, base);
    }

    // Lagrange Interpolation to find f(0)
    public static BigInteger findSecret(Map<Integer, BigInteger> points, int k) {

        BigInteger secret = BigInteger.ZERO;

        // Sort x values
        List<Integer> xValues = new ArrayList<>(points.keySet());
        Collections.sort(xValues);

        for (int i = 0; i < k; i++) {

            BigInteger xi = BigInteger.valueOf(xValues.get(i));
            BigInteger yi = points.get(xValues.get(i));

            BigInteger numerator = BigInteger.ONE;
            BigInteger denominator = BigInteger.ONE;

            for (int j = 0; j < k; j++) {
                if (i != j) {
                    BigInteger xj = BigInteger.valueOf(xValues.get(j));
                    numerator = numerator.multiply(xj.negate());
                    denominator = denominator.multiply(xi.subtract(xj));
                }
            }

            // Multiply fully first
            BigInteger term = yi.multiply(numerator);

            // Then divide
            term = term.divide(denominator);

            secret = secret.add(term);
        }

        return secret.abs(); // ensure positive output
    }

    // Solve function (takes JSON input)
    public static BigInteger solve(String jsonInput) {

        JSONObject obj = new JSONObject(jsonInput);

        int k = obj.getJSONObject("keys").getInt("k");

        Map<Integer, BigInteger> points = new LinkedHashMap<>();

        for (String key : obj.keySet()) {

            if (!key.equals("keys")) {

                int x = Integer.parseInt(key);
                JSONObject root = obj.getJSONObject(key);

                int base = Integer.parseInt(root.getString("base"));
                String value = root.getString("value");

                BigInteger y = convertToDecimal(value, base);

                points.put(x, y);
            }
        }

        return findSecret(points, k);
    }

    public static void main(String[] args) {

        String jsonString = """
        PASTE YOUR FULL JSON HERE
        """;

        BigInteger result = solve(jsonString);

        System.out.println("Secret (f(0)):");
        System.out.println(result);
    }
}